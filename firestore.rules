rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Covers every subcollection under a user's own document (deliveryLogs,
      // settings, and any future one) — a rule on the parent doc does not
      // cascade to subcollections in Firestore without this.
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /payPeriodData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /invoiceData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /addressMemoryData/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
